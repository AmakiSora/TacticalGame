# Copy this file to .env on the VPS. Do not commit the populated .env file.

# App runtime
PORT=3100
HOST=0.0.0.0
LOG_LEVEL=info
TRUST_PROXY=false
TACTICAL_GAME_STATE_FILE=/app/runtime/games.json

# Required: protect remote control endpoints even though Caddy also requires a password.
AUTO_CONTROL_TOKEN=replace-with-a-long-random-control-token

# Caddy basic authentication. Generate the hash on the VPS:
# docker run --rm caddy:2.10.0-alpine caddy hash-password --plaintext 'choose-a-long-password'
CADDY_AUTH_USER=operator
CADDY_AUTH_HASH=replace-with-the-generated-bcrypt-hash

# IP testing defaults to unencrypted HTTP on this non-privileged host port.
# Change to 80 after firewall rules are ready, or use 443 after moving to a domain/TLS configuration.
PROXY_PORT=8080
