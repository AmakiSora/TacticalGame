# Copy this file to .env on the VPS. Do not commit the populated .env file.

# App runtime
PORT=3123
HOST=0.0.0.0
LOG_LEVEL=info
TRUST_PROXY=false
TACTICAL_GAME_STATE_FILE=/app/runtime/games.json

# Required: protect remote control endpoints. Generate with: openssl rand -hex 32
AUTO_CONTROL_TOKEN=replace-with-a-long-random-control-token
